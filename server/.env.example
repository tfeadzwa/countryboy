# Copy this file to .env and fill the real values. DO NOT commit secrets.
NODE_ENV=production
PORT=3000

# Database (example)
# Replace placeholders with real values before running in production
DATABASE_URL="postgresql://countryboy_user:STRONG_DB_PASSWORD@localhost:5432/countryboy_prod"

# JWT secrets (generate securely on the server)
JWT_SECRET=CHANGE_ME_GENERATE_ON_SERVER
JWT_RESET_SECRET=CHANGE_ME_GENERATE_ON_SERVER_DIFFERENT

# CORS — comma-separated origins allowed to access the API
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Frontend base URL (used for some server-side links)
FRONTEND_BASE_URL=http://localhost:8080

# SMTP (for sending emails) — example placeholders
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=supersecret
